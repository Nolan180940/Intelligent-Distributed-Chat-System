# Copy this file to .env and fill in your API keys
# Do NOT commit your real .env file to version control.

# ===== SiliconFlow API (primary AI provider) =====
# Get your key at: https://cloud.siliconflow.cn/account/ak
SILICONFLOW_API_KEY=
SILICONFLOW_BASE_URL=https://api.siliconflow.cn/v1
SILICONFLOW_MODEL=Pro/MiniMaxAI/MiniMax-M2.5

# ===== Pollinations image API (optional) =====
POLLINATIONS_API_KEY=

# ===== Ollama (local fallback) =====
# OLLAMA_HOST=http://localhost:11434
# OLLAMA_MODEL=phi3:mini
